{% extends basePath %}

{% block body %}
    <section class="list {{ listClasses }} headerList">
        <div>
            <div class="div1">{{ columnName['column1'] }}</div>
            <div class="div2">{{ columnName['column2'] }}</div>
            <div class="div3">{{ columnName['column3'] }}</div>
            <div class="div4">{{ columnName['column4'] }}</div>
            <div class="div5">{{ columnName['column5'] }}</div>
            <div class="div6">{{ columnName['column6'] }}</div>
        </div>
    </section>
<section class="list {{ listClasses }}">
    {% for i in 0..(data|length - 1) %}
        {% include itemPath %}
    {% endfor %}
</section>
{% endblock %}