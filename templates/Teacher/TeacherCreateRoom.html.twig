{% extends "Base/Base.html.twig" %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Styles/Teacher/Teacher.css')}}">
    <link rel="stylesheet" href="{{ asset('Styles/Base/Form.css')}}">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('JS/Teacher/Create.js') }}" defer></script>
{% endblock %}

{% block headerLeft %}
    {% include 'Teacher/Assets/ButtonRoom.html.twig' %}
{% endblock %}

{% block body %}
<div class="form">
    <form id="createRoomForm" method="POST" >
        <label for="roomName">Nom salon :</label>
        <input type="text" id="roomName" name="roomName" autocomplete="off" required>

        <label for="roomDescription">Description :</label>
        <input type="text" id="roomDescription" name="roomDescription" autocomplete="off" required>

        <button class="valid-button" type="submit">Valider</button><br>
        <hr>
        <button class="discard-button" type="button" onclick="goToPath('/teacher');">Annuler</button>
    </form>
</div>
{% endblock %}

