<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('/Styles/Base/Base.css')}}">
        <link rel="stylesheet" href="{{ asset('/Styles/PopUp/PopUpHeader.css')}}">

        {% block stylesheets %}
        {% endblock %}

        <script src="{{ asset('JS/PopUp/PopUp.js') }}"></script>
        <script src="{{ asset('JS/Base/PageManager.js') }}"></script>
        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
        <header>
            <div id="header-left">
                    {% if is_granted('ROLE_ADMIN') %}
                       <img id="logo" src="{{ asset('Styles/Base/img/logo.png') }}" alt="logo" onclick="goToPath('/admin')"/>
                    {% elseif is_granted('ROLE_TEACHER') %}
                        <img id="logo" src="{{ asset('Styles/Base/img/logo.png') }}" alt="logo" onclick="goToPath('/teacher')"/>
                    {% elseif is_granted('ROLE_STUDENT') %}
                        <img id="logo" src="{{ asset('Styles/Base/img/logo.png') }}" alt="logo" onclick="goToPath('/student')"/>
                    {% else %}
                        <img id="logo" src="{{ asset('Styles/Base/img/logo.png') }}" alt="logo" onclick="goToPath('/')" />
                    {% endif %}

                {% block headerLeft %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <button class="home-button" onclick="goToPath('/admin')">Gestion d'accès</button>
                    {% elseif is_granted('ROLE_TEACHER') %}
                        <button class="home-button" onclick="goToPath('/teacher')">Salons</button>
                    {% elseif is_granted('ROLE_STUDENT') %}
                        <button class="home-button" onclick="goToPath('/student')">Chapitres</button>
                    {% elseif is_granted('ROLE_PENDING_STUDENT') or is_granted('ROLE_PENDING_TEACHER')%}

                    {% endif %}
                {% endblock %}
            </div>

            <div id="header-right">
                {% block headerRight %}
                    {% if app.user %}
                        <div id="pseudo-role">
                            <p>{{ app.user.firstName }} {{ app.user.lastName }}</p>
                            {% if is_granted('ROLE_ADMIN') %}
                                <p> Administrateur·rice </p>
                            {% elseif is_granted('ROLE_TEACHER')%}
                                <p> Professeur·e</p>
                            {% elseif is_granted('ROLE_STUDENT')%}
                                <p> Élève </p>
                            {% elseif (is_granted('ROLE_PENDING_STUDENT')) or (is_granted('ROLE_PENDING_TEACHER')) %}
                                <p> En attente de validation</p>
                            {% endif %}
                            {% include "PopUp/PopUpHeader.html.twig" %}
                        </div>
                        <img id=profil src="{{ asset('Styles/Base/img/profil.png') }}" alt="" onclick="togglePopupHeader()">
                    {% else %}
                        <button class="home-button" onclick="goToPath('/register');">Demande d'inscription</button>
                        <button class="home-button" onclick="goToPath('/login');">Se connecter</button>
                    {% endif %}

                {% endblock %}
            </div>
        </header>

        <main>
            {% block pageHeader %}
            <div class="pageHeader">
                <h1>{{ pageName }}</h1>
                <hr>
            </div>
            {% endblock %}

            {% block body %}
            {% endblock %}
            {% block popup %}{% endblock %}
            <section class="pageFooter">{% block pageFooter %}{% endblock %}</section>
        </main>
        {% block footer %}
        <footer>
            <p>Organizing History</p>
            <div class="links">
                <a href="/terms-of-use"> Conditions d'utilisation </a>
                <a href="/contact-form"> Formulaire de contact</a>
            </div>
        </footer>
        {% endblock %}

        {% if app.session.get('demo_student_id') %}
        <div id="demo-widget">
            <div id="demo-panel" style="display:none;">
                <p style="margin:0 0 8px; font-weight:bold; color:#333;">Session démo</p>
                <table style="border-collapse:collapse; width:100%; font-size:0.9em; color:#333;">
                    <tr>
                        <td style="padding:4px 8px 4px 0; color:#555;">Élève</td>
                        <td style="padding:4px 0;"><strong>{{ app.session.get('demo_student_username') }}</strong></td>
                    </tr>
                    <tr>
                        <td style="padding:4px 8px 4px 0; color:#555;">Professeur</td>
                        <td style="padding:4px 0;"><strong>{{ app.session.get('demo_teacher_username') }}</strong></td>
                    </tr>
                    <tr>
                        <td style="padding:4px 8px 4px 0; color:#555;">Mot de passe</td>
                        <td style="padding:4px 0;"><strong>{{ app.session.get('demo_password') }}</strong></td>
                    </tr>
                </table>
                <hr style="margin:10px 0; border:none; border-top:1px solid #ddd;">
                <a href="/demo/stop" style="color:#c0392b; font-size:0.85em;">Arrêter la démo</a>
            </div>
            <button id="demo-toggle" onclick="
                var p = document.getElementById('demo-panel');
                p.style.display = p.style.display === 'none' ? 'block' : 'none';
            ">🎓 Démo</button>
        </div>
        <style>
            #demo-widget {
                position: fixed;
                bottom: 20px;
                right: 20px;
                z-index: 9999;
                text-align: right;
            }
            #demo-panel {
                background: white;
                border: 1px solid #ccc;
                border-radius: 8px;
                padding: 14px 16px;
                margin-bottom: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.15);
                text-align: left;
                min-width: 240px;
            }
            #demo-toggle {
                background: #555;
                color: white;
                border: 3px solid #333;
                border-bottom-left-radius: 15px 255px;
                border-bottom-right-radius: 225px 15px;
                border-top-left-radius: 255px 15px;
                border-top-right-radius: 15px 225px;
                padding: 8px 16px;
                cursor: pointer;
                font-size: 0.9em;
                font-family: 'Quicksand', sans-serif;
            }
            #demo-toggle:hover { background: #333; }
        </style>
        {% endif %}
    </body>
</html>
