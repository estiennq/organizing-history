{% extends 'Base/Base.html.twig' %}

{% block body %}
    <section class="join" style="flex-direction: column; align-items: center; padding: 60px 20px; gap: 20px;">
        <h1 style="text-align: center; color: #333;">Votre session de démo</h1>
        <p style="text-align: center; color: #333;">Ces comptes sont temporaires et seront supprimés à la fin de la démo.</p>

        <div style="display: flex; gap: 40px; flex-wrap: wrap; justify-content: center; margin-top: 20px;">
            <div style="background: white; border: 2px solid #ccc; border-radius: 10px; padding: 30px; min-width: 220px;">
                <h2 style="margin-top: 0; color: #333;">Élève</h2>
                <p style="color: #333;"><strong>Identifiant :</strong> {{ studentUsername }}</p>
                <p style="color: #333;"><strong>Mot de passe :</strong> {{ password }}</p>
            </div>
            <div style="background: white; border: 2px solid #ccc; border-radius: 10px; padding: 30px; min-width: 220px;">
                <h2 style="margin-top: 0; color: #333;">Professeur</h2>
                <p style="color: #333;"><strong>Identifiant :</strong> {{ teacherUsername }}</p>
                <p style="color: #333;"><strong>Mot de passe :</strong> {{ password }}</p>
            </div>
        </div>

        <div class="button-container" style="margin-top: 30px; gap: 15px;">
            <button class="home-button" onclick="goToPath('/login');">Se connecter</button>
            <button class="home-button" style="background: #888;" onclick="goToPath('/demo/stop');">Arrêter la démo</button>
        </div>
    </section>
{% endblock %}
